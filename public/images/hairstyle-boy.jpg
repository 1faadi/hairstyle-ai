(function() {
  // Remove <font> tags injected by translation plugins (e.g. Google Translate on Android)
  // These tags wrap text nodes and cause React hydration mismatch errors
  try {
    document.querySelectorAll('font').forEach(function(font) {
      var parent = font.parentNode;
      if (parent) {
        while (font.firstChild) {
          parent.insertBefore(font.firstChild, font);
        }
        parent.removeChild(font);
      }
    });
  } catch(e) {}
})();
