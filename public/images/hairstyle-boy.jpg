:\"Crew Cut\",\"Slicked Back\":\"Slicked Back\"},\"haircolor\":{\"Random\":\"Random\",\"No change\":\"No change\",\"Black\":\"Black\",\"Brown\":\"Brown\",\"Blonde\":\"Blonde\",\"Red\":\"Red\",\"Auburn\":\"Auburn\",\"Silver\":\"Silver\",\"Blue\":\"Blue\",\"Purple\":\"Purple\",\"Pink\":\"Pink\",\"Green\":\"Green\"}}}}],[\"$\",\"$L20\",null,{\"section\":{\"advancedScan\":{\"id\":\"instant-try-on\",\"tabName\":\"Instant Hairstyle Try On\",\"mainTitle\":\"See Yourself with Any Hairstyle\",\"mainDescription\":\"Our hairstyle AI instantly applies any hairstyle to your photo with realistic results. No more guessing how you'll look - see it before you cut it!\"},\"aiVocabulary\":{\"id\":\"style-selection\",\"tabName\":\"Easy Style Selection\",\"mainTitle\":\"Choose from Hundreds of Styles\",\"mainDescription\":\"Browse through our extensive collection of hairstyles and select your favorite. Our AI hairstyle changer offers options for every taste and preference.\"},\"plagiarismChecker\":{\"id\":\"color-experimentation\",\"tabName\":\"Hair Color Experimentation\",\"mainTitle\":\"Try Any Hair Color Instantly\",\"mainDescription\":\"Experiment with every hair color imaginable using our hairstyle try on technology. From natural shades to bold fashion colors, see what works best for you.\"}}}],\"$L21\",\"$L22\",\"$L23\",\"$L24\",\"$L25\",\"$undefined\"]}]\n"])</script><script>self.__next_f.push([1,"21:[\"$\",\"$L26\",null,{\"section\":{\"title\":\"Why Choose Our Hairstyle AI\",\"description\":\"Powered by cutting-edge AI technology and trusted by thousands of users worldwide\",\"items\":[{\"value\":\"500+\",\"label\":\"Hairstyles Available\",\"description\":\"From classic cuts to trendy styles, our AI hairstyle changer offers the most comprehensive selection of hairstyles for every taste and occasion\"},{\"value\":\"\u003c 10sec\",\"label\":\"Lightning Fast Results\",\"description\":\"Get instant hairstyle transformations with our optimized AI technology that processes your hairstyle try on in seconds\"},{\"value\":\"99.9%\",\"label\":\"Satisfaction Rate\",\"description\":\"Users love the realistic results from our hairstyle AI and the confidence it gives them to make the right hair decisions\"},{\"value\":\"24/7\",\"label\":\"Always Available\",\"description\":\"Try on hairstyles anytime, anywhere with our AI hairstyle changer that works perfectly on all devices\"}]}}]\n"])</script><script>self.__next_f.push([1,"22:[\"$\",\"$L27\",null,{\"section\":{\"title\":\"Hair Decisions Are Hard — Hairstyle AI Makes Them Easy\",\"description\":\"We understand the struggle of choosing the perfect hairstyle. Here's how our AI hairstyle changer solves your biggest hair dilemmas with confidence.\",\"concernTitle\":\"Your Hair Concern\",\"solutionTitle\":\"How Hairstyle AI Helps\",\"painDescription\":\"Many people struggle with {pain} when choosing a new hairstyle, leading to regret and expensive mistakes.\",\"extendedSolutions\":[\"See exactly how any hairstyle will look on you before committing to a cut with our realistic hairstyle AI preview technology.\",\"Try hundreds of different styles, lengths, and colors instantly with our AI hairstyle changer without any risk or commitment.\",\"Experiment with different looks using our easy-to-use interface that lets you upload your photo and try various styles within minutes.\",\"Save time and money by avoiding salon consultations and hair disasters - know exactly what you want before you go to the stylist.\"],\"ctaText\":\"Try Hairstyle AI Now\",\"items\":[{\"pain\":\"Fear of Making the Wrong Haircut Choice\",\"solution\":\"Risk-Free Virtual Hairstyle Try On\",\"icon\":\"RiScissorsLine\"},{\"pain\":\"Uncertainty About New Hairstyle Options\",\"solution\":\"Instant Hairstyle Preview Technology\",\"icon\":\"RiEyeLine\"},{\"pain\":\"Wondering How Different Hair Colors Look\",\"solution\":\"Instant Hair Color Experimentation\",\"icon\":\"RiPaletteLine\"},{\"pain\":\"Expensive Salon Consultation and Regret\",\"solution\":\"Free AI Hairstyle Changer Preview\",\"icon\":\"RiMoneyDollarCircleLine\"}]}}]\n"])</script><script>self.__next_f.push([1,"23:[\"$\",\"$L28\",null,{\"section\":{\"title\":\"How to Use Our Hairstyle AI\",\"description\":\"Transform your look in minutes with our easy-to-use AI hairstyle changer. Follow these simple steps to discover your perfect hairstyle.\",\"steps\":[{\"title\":\"Upload Your Photo\",\"description\":\"Start by uploading a clear, front-facing photo of yourself. Our hairstyle AI works best with good lighting and a neutral background. Make sure your current hairstyle and face shape are clearly visible for the most accurate results.\",\"icon\":\"RiImageAddLine\"},{\"title\":\"Browse and Select Hairstyles\",\"description\":\"Explore our extensive library of hairstyles organized by categories like short, medium, long, and trending styles. Our AI hairstyle changer offers options for all hair types, making it easy to find styles that interest you.\",\"icon\":\"RiGridLine\"},{\"title\":\"Watch the AI Magic Happen\",\"description\":\"Our advanced hairstyle AI processes your photo and seamlessly applies your chosen hairstyle. The process takes just seconds, and you'll see a realistic preview of how you'll look with your new hairstyle try on.\",\"icon\":\"RiMagicLine\"},{\"title\":\"Save and Share Your Results\",\"description\":\"Love your new look? Download the high-quality image and share it with friends or take it to your stylist. Try multiple styles and compare them side by side to make the perfect choice for your next haircut.\",\"icon\":\"RiDownloadLine\"}],\"cta\":{\"text\":\"Start Your Hairstyle Transformation\",\"url\":\"/\"}}}]\n"])</script><script>self.__next_f.push([1,"24:[\"$\",\"$L29\",null,{\"section\":{\"name\":\"testimonial\",\"label\":\"Testimonial\",\"title\":\"What Users Say About Our Hairstyle AI\",\"icon\":\"GoThumbsup\",\"items\":[{\"title\":\"Sarah M.\",\"label\":\"Fashion Blogger\",\"description\":\"I was nervous about cutting my long hair, but the hairstyle AI showed me exactly how I'd look with a bob. The results were so realistic! I took the image to my stylist and got the exact cut. I absolutely love it and get compliments every day.\",\"image\":{\"src\":\"/imgs/users/sarah-hairstyle-ai.png\",\"alt\":\"Sarah using hairstyle AI for haircut decision\"}},{\"title\":\"Mike T.\",\"label\":\"College Student\",\"description\":\"As a guy who's always had the same haircut, I wanted to try something new but wasn't sure what would work. The AI hairstyle changer let me experiment with tons of styles. Found an awesome undercut that looks great on me!\",\"image\":{\"src\":\"/imgs/users/mike-hairstyle-change.png\",\"alt\":\"Mike trying different hairstyles with AI\"}},{\"title\":\"Emma L.\",\"label\":\"Working Professional\",\"description\":\"I needed a professional hairstyle for my new job but didn't want to risk a bad cut. The hairstyle try on feature was perfect! I could see exactly how different styles would look before making any decisions.\",\"image\":{\"src\":\"/imgs/users/emma-professional-hairstyle.png\",\"alt\":\"Emma finding professional hairstyle with AI\"}},{\"title\":\"James R.\",\"label\":\"Creative Designer\",\"description\":\"The hairstyle AI is incredibly realistic. I tried about 20 different styles and colors before settling on my current look. My friends couldn't believe how accurate the preview was compared to my actual haircut.\",\"image\":{\"src\":\"/imgs/users/james-creative-hairstyle.png\",\"alt\":\"James exploring creative hairstyles with AI\"}},{\"title\":\"Lisa K.\",\"label\":\"Busy Mom\",\"description\":\"Between work and kids, I don't have time for multiple salon visits. The AI hairstyle changer saved me so much time! I could try different looks at home and found the perfect style that's both cute and easy to maintain.\",\"image\":{\"src\":\"/imgs/users/lisa-busy-mom-hairstyle.png\",\"alt\":\"Lisa finding practical hairstyle with AI\"}},{\"title\":\"Carlos D.\",\"label\":\"Fitness Trainer\",\"description\":\"I wanted a hairstyle that would work well for my active lifestyle. The hairstyle AI helped me explore different sporty cuts and find one that looks great whether I'm at the gym or out with friends. Super convenient tool!\",\"image\":{\"src\":\"/imgs/users/carlos-sporty-hairstyle.png\",\"alt\":\"Carlos finding sporty hairstyle with AI\"}}]}}]\n"])</script><script>self.__next_f.push([1,"25:[\"$\",\"section\",null,{\"id\":\"faq\",\"className\":\"py-16\",\"children\":[\"$\",\"div\",null,{\"className\":\"container\",\"children\":[[\"$\",\"div\",null,{\"className\":\"text-center\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"mt-4 text-4xl font-semibold\",\"children\":\"Frequently Asked Questions About Hairstyle AI\"}],[\"$\",\"p\",null,{\"className\":\"mt-6 font-medium text-muted-foreground\",\"children\":\"Got questions? We've got answers! Contact us at support@hairstyleai.ai\"}]]}],[\"$\",\"div\",null,{\"className\":\"mx-auto mt-14 grid gap-8 md:grid-cols-2 md:gap-12\",\"children\":[[\"$\",\"div\",\"0\",{\"className\":\"flex gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"flex size-6 shrink-0 items-center justify-center rounded-sm border border-primary font-mono text-xs text-primary\",\"children\":1}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-2 flex items-center justify-between\",\"children\":[\"$\",\"h3\",null,{\"className\":\"font-semibold\",\"children\":\"How accurate is the hairstyle AI?\"}]}],[\"$\",\"p\",null,{\"className\":\"text-md text-muted-foreground\",\"children\":\"Our AI hairstyle changer uses advanced machine learning algorithms trained on millions of hairstyle images. While results are highly realistic, remember that the final outcome may vary slightly based on your hair texture, thickness, and styling preferences. We recommend showing the AI result to your stylist as a reference.\"}]]}]]}],[\"$\",\"div\",\"1\",{\"className\":\"flex gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"flex size-6 shrink-0 items-center justify-center rounded-sm border border-primary font-mono text-xs text-primary\",\"children\":2}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-2 flex items-center justify-between\",\"children\":[\"$\",\"h3\",null,{\"className\":\"font-semibold\",\"children\":\"What types of photos work best with the hairstyle AI?\"}]}],[\"$\",\"p\",null,{\"className\":\"text-md text-muted-foreground\",\"children\":\"For the best hairstyle try on results, use a clear, front-facing photo with good lighting. Avoid sunglasses, hats, or anything covering your hairline. The AI works best when it can clearly see your face shape and current hair.\"}]]}]]}],[\"$\",\"div\",\"2\",{\"className\":\"flex gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"flex size-6 shrink-0 items-center justify-center rounded-sm border border-primary font-mono text-xs text-primary\",\"children\":3}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-2 flex items-center justify-between\",\"children\":[\"$\",\"h3\",null,{\"className\":\"font-semibold\",\"children\":\"Is my photo data safe with your hairstyle AI?\"}]}],[\"$\",\"p\",null,{\"className\":\"text-md text-muted-foreground\",\"children\":\"Absolutely! We take privacy seriously. Your photos are processed securely and deleted from our servers after 24 hours. We never store, share, or use your images for any purpose other than generating your hairstyle transformations.\"}]]}]]}],[\"$\",\"div\",\"3\",{\"className\":\"flex gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"flex size-6 shrink-0 items-center justify-center rounded-sm border border-primary font-mono text-xs text-primary\",\"children\":4}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-2 flex items-center justify-between\",\"children\":[\"$\",\"h3\",null,{\"className\":\"font-semibold\",\"children\":\"Can I try multiple hairstyles with one ph